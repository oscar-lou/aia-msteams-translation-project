# =============================================================
#  Copy this file to ".env" and fill in the values.
# =============================================================

# --- Azure Bot registration (README step 2) ---
# The App (client) ID of the bot's Entra app registration
MicrosoftAppId=
# The client secret VALUE for that app registration
MicrosoftAppPassword=
# SingleTenant: the app is registered in one specific tenant (this was the only
# option available when creating via the Azure Bot wizard). MicrosoftAppTenantId
# is REQUIRED when using SingleTenant — the bot won't authenticate without it.
MicrosoftAppType=SingleTenant
MicrosoftAppTenantId=

# --- Translation engine (DeepL) ---
# Free tier key from deepl.com/pro-api (no credit card needed) — free-tier keys
# end in ":fx" and only work against the api-free.deepl.com endpoint used here.
DEEPL_API_KEY=

# Language behaviour:
# CHINESE_SCRIPT sets which script to use when translating English INTO Chinese.
#   Traditional = Hong Kong / Taiwan,  Simplified = mainland China
CHINESE_SCRIPT=Traditional
# Optional: pin a single output language regardless of input. Must be a valid
# DeepL target_lang code (e.g. "EN-US", "ZH-HANT") — NOT a freeform language
# name. Leave blank for default bidirectional Chinese <-> English behaviour.
FORCE_TARGET_LANG=

# --- Local server ---
PORT=3978
