{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run & Debug Translate Bot",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/index.js",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "restart": true
    }
  ]
}
