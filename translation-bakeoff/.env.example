# Copy this file to ".env" and fill in.

# Required: Qwen via Alibaba Cloud Model Studio (OpenAI-compatible, no HK
# restriction). Get a key from the Model Studio console (bailian console
# -> API-KEY management). Free quota is Singapore-region only.
QWEN_API_KEY=

# Required: the OpenAI-compatible base URL from your Model Studio console —
# do NOT hardcode this. Alibaba is migrating to workspace-specific domains
# (e.g. https://ws-xxxxxxxx.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1),
# so copy the exact URL shown in your console. "/chat/completions" is appended
# automatically — don't include it here.
QWEN_BASE_URL=

# Required: comma-separated list of model names to test, each gets its own
# column in results.md (e.g. "Qwen (qwen-plus)"). Example: qwen-plus,qwen-max
QWEN_MODELS=qwen-plus

# Script to use when translating English -> Chinese output
# Traditional = Hong Kong / Taiwan,  Simplified = mainland
CHINESE_SCRIPT=Traditional

# Optional: compare Qwen against DeepL on the same messages.
# Free tier key from deepl.com/pro-api (no credit card needed) — free-tier keys
# end in ":fx" and only work against the api-free.deepl.com endpoint used here.
# Leave blank to skip the DeepL column entirely.
DEEPL_API_KEY=

# Optional: how many messages to bundle into each Qwen API call (default 4).
# Higher = fewer requests against quota, but a single failure or safety-filter
# trip affects more messages at once. Each QWEN_MODELS entry batches separately.
# Ignored when SINGLE_MESSAGE_MODE=true (see below).
BATCH_SIZE=4

# Optional: set true to bypass batching entirely and send one message per API
# call for every batch-capable engine (Gemini/Qwen/DeepSeek), matching
# production behaviour exactly. Default false keeps the existing multi-message
# batching. Token/cost/latency are captured in both modes, but batched-mode
# cost-per-message is an underestimate of real production cost — see the
# warning results.md prints when this is false.
SINGLE_MESSAGE_MODE=false

# Optional: compare Qwen/DeepL against Azure OpenAI on the same messages.
# All four vars below must be set or this column is skipped entirely.
# Azure portal -> your Azure OpenAI resource -> "Keys and Endpoint":
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# The deployment name you chose when deploying a model (Azure AI Studio / Azure
# OpenAI Studio -> your resource -> Deployments tab) — not the base model name.
AZURE_OPENAI_DEPLOYMENT=
# REST API version to call. 2024-10-21 is a stable GA version; check
# learn.microsoft.com/azure/ai-services/openai/reference for current options.
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional: compare against DeepSeek (OpenAI-compatible) on the same messages.
# Get a key at platform.deepseek.com — new accounts get a free 5M-token grant
# valid for 30 days, no card required. Leave DEEPSEEK_API_KEY blank to skip
# these columns entirely.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Comma-separated list, e.g. "deepseek-v4-flash,deepseek-v4-pro". Use
# deepseek-v4-flash, NOT the legacy deepseek-chat/deepseek-reasoner aliases —
# those are deprecated and retire 2026-07-24 15:59 UTC with no fallback.
DEEPSEEK_MODELS=deepseek-v4-flash

# Optional: compare against Gemini on the same messages. Gemini's API is
# geo-blocked in Hong Kong for normal use — this is for informal, VPN-based
# validation testing only (e.g. checking whether a stronger tier like
# gemini-2.5-pro actually beats DeepL where flash-lite only tied it), NOT a
# deployment candidate. Leave GEMINI_API_KEY blank to skip this column.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional: broad first-pass screen across many Azure AI Foundry deployments
# on ONE endpoint + ONE key (OpenAI-compatible Chat Completions API),
# differing only by deployment name. Add/remove models by editing
# FOUNDRY_MODELS alone — no code change per model. Leave FOUNDRY_ENDPOINT
# blank to skip this entirely.
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
# No FOUNDRY_API_VERSION here on purpose: the endpoint this script calls
# (POST {endpoint}/openai/v1/chat/completions) rejects an "api-version" query
# param outright ("not allowed when using /v1 path") — confirmed live,
# 2026-07. There's currently no working knob to add here.
#
# Comma-separated deployment names, EXACTLY as they appear in your Foundry
# resource's Deployments tab — these are names you chose when deploying, not
# fixed vendor IDs, so verify each one there before trusting a result.
#
# Do NOT add text-embedding-* deployments here — embedding models return
# vector representations, not text, and cannot translate.
#
# Flagged rather than silently included — verify these specifically:
#  - "gpt-5-mini" appeared twice in the original candidate list; deduped to one.
#  - "o3" is a reasoning model. Azure reasoning-model deployments have
#    historically rejected "temperature" and/or required a "developer" role
#    instead of "system" — expect it to need special-casing or fail outright;
#    that's a request-shape issue, not evidence it can't translate.
#  - "Kimi-K2.6" / "Kimi-K2.5": exact model/version naming not independently
#    verifiable here — confirm both exist in your model catalog before relying
#    on them.
FOUNDRY_MODELS=gpt-5-mini,gpt-5-nano,gpt-5-chat,gpt-5.1,gpt-4.1,gpt-4.1-nano,DeepSeek-V4-Flash,DeepSeek-V4-Pro,Kimi-K2.6,Kimi-K2.5,o3
