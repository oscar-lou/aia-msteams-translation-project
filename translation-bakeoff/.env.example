# Copy this file to ".env" and fill in.

# Required: your Gemini API key from Google AI Studio (aistudio.google.com/apikey)
GEMINI_API_KEY=

# Model to use for translation.
# gemini-2.5-flash is currently free-tier eligible and a good default (fast, capable).
# Model names/free-tier eligibility change fairly often — if you get errors or want to
# compare quality, check the current list at https://aistudio.google.com (Get API Key
# page shows your project's available/free models) or ai.google.dev/gemini-api/docs/models.
GEMINI_MODEL=gemini-2.5-flash

# Script to use when translating English -> Chinese output
# Traditional = Hong Kong / Taiwan,  Simplified = mainland
CHINESE_SCRIPT=Traditional

# Optional: compare Gemini against DeepL on the same messages.
# Free tier key from deepl.com/pro-api (no credit card needed) — free-tier keys
# end in ":fx" and only work against the api-free.deepl.com endpoint used here.
# Leave blank to skip the DeepL column entirely.
DEEPL_API_KEY=

# Optional: how many messages to bundle into each Gemini API call (default 4).
# Higher = fewer requests against free-tier quota, but a single failure or
# safety-filter trip affects more messages at once.
BATCH_SIZE=4

# Optional: compare Gemini/DeepL against Azure OpenAI on the same messages.
# All four vars below must be set or this column is skipped entirely.
# Azure portal -> your Azure OpenAI resource -> "Keys and Endpoint":
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# The deployment name you chose when deploying a model (Azure AI Studio / Azure
# OpenAI Studio -> your resource -> Deployments tab) — not the base model name.
AZURE_OPENAI_DEPLOYMENT=
# REST API version to call. 2024-10-21 is a stable GA version; check
# learn.microsoft.com/azure/ai-services/openai/reference for current options.
AZURE_OPENAI_API_VERSION=2024-10-21
